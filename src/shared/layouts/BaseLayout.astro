---
import '../../styles/global.css';
const { title = 'My Affiliate' } = Astro.props;
---
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content="Affiliate site starter" />
  </head>
  <body class="min-h-screen bg-white text-slate-900">
    <header class="py-4 border-b">
      <div class="container mx-auto px-4">
        <a href="/" class="text-xl font-bold">My Affiliate</a>
      </div>
    </header>
    <main class="container mx-auto px-4 py-8">
      <slot />
    </main>
    <footer class="border-t py-6 text-center text-sm text-slate-500">
      © {new Date().getFullYear()} My Affiliate
    </footer>
  </body>
</html>
